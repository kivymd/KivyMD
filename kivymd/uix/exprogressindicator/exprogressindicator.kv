<MDExBaseProgressBar>:
    active_track_color: self.theme_cls.primaryColor
    inactive_track_color: self.theme_cls.surfaceContainerHighestColor

<MDExCircularProgressIndicator>:
    canvas:
        Color:
            group:"active_track_color"
            rgba: root.active_track_color 
        Line: 
            group:"active_track"
            cap:"round"
            joint:"round"
            width: self.thickness/2
        Color:
            group:"inactive_track_color"
            rgba:root.inactive_track_color 
        Line: 
            group:"inactive_track"
            cap:"round"
            width: self.thickness/2

<MDExLinearProgressIndicator>
    canvas:
        
        Color:
            rgba:root.inactive_track_color 
            group:"inactive_track_color"
        Line: 
            group:"inactive_track"
            cap:"round"
            joint:"round"
            width: self.thickness/2

        Color:
            rgba:root.inactive_track_color 
            group:"inactive_track_1_color"
        Line: 
            group:"inactive_track_1"
            cap:"round"
            joint:"round"
            width: self.thickness/2


        Color:
            group:"active_track_color"
            rgba:root.active_track_color 
        Line: 
            group:"active_track"
            cap:"round"
            joint:"round"
            width: self.thickness/2
            
        Color:
            group:"active_track_1_color"
            rgba:root.active_track_color
        Line: 
            group:"active_track_1"
            cap:"round"
            joint:"round"
            width: self.thickness/2

        Color:
            group:"dot"
            rgba: root.inactive_track_color       
        
        Ellipse:
            size: [dp(4)]*2
            pos:
                (
                self.x + self.width - dp(4) - (self.thickness - dp(4))/2,
                self.center_y - dp(2)
                ) if self.orientation == "horizontal" else (
                self.center_x - dp(2),
                self.y + self.height - dp(4) - (self.thickness - dp(4))/2
                )

